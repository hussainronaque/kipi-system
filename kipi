#!/bin/bash
set -euo pipefail

KIPI_HOME="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"

usage() {
  echo "kipi - manage your entrepreneur OS instances"
  echo ""
  echo "  kipi update          Pull latest skeleton into all projects"
  echo "  kipi update --dry    Show what would happen without changing anything"
  echo "  kipi rollback [name]  Revert the last skeleton sync (all instances, or one by name)"
  echo "  kipi new <path> <name>   Create a new project with the skeleton"
  echo "  kipi push            Push generic improvements back to skeleton (run from a project)"
  echo "  kipi dev             Launch Claude Code with all kipi plugins loaded"
  echo "  kipi check [phase]   Run validation harness (default: all phases)"
  echo "  kipi migrate <path>  Migrate instance to full kipi compliance"
  echo "  kipi migrate <path> --dry-run  Preview migration without changes"
  echo "  kipi cluster add <path> <name> <role>  Plug an instance into the KTLYST cluster"
  echo "  kipi cluster sync    Re-run all bridge writers (push latest state to all instances)"
  echo "  kipi list            Show all registered projects"
  echo "  kipi home            Print the skeleton path"
  echo ""
}

case "${1:-help}" in
  update)
    shift || true
    if [ "${1:-}" = "--dry" ]; then
      bash "$KIPI_HOME/kipi-update.sh" --dry-run
    else
      bash "$KIPI_HOME/kipi-update.sh"
    fi
    ;;
  rollback)
    shift || true
    bash "$KIPI_HOME/kipi-rollback.sh" "$@"
    ;;
  new)
    shift
    bash "$KIPI_HOME/kipi-new-instance.sh" "$@"
    ;;
  dev)
    claude --plugin-dir "$KIPI_HOME/plugins/kipi-core" \
           --plugin-dir "$KIPI_HOME/plugins/kipi-ops" \
           --plugin-dir "$KIPI_HOME/plugins/kipi-design"
    ;;
  sync-skills)
    echo "DEPRECATED: Skills are now distributed via marketplace plugins."
    echo "Instances use extraKnownMarketplaces + enabledPlugins in .claude/settings.json"
    echo "See plugins/ directory for kipi-core, kipi-ops, kipi-design"
    ;;
  push)
    bash "$KIPI_HOME/kipi-push-upstream.sh"
    ;;
  check)
    shift || true
    cd "$KIPI_HOME"
    python3 validate-separation.py "${1:-5}"
    ;;
  migrate)
    shift
    python3 "$KIPI_HOME/kipi-migrate.py" "$@"
    ;;
  cluster)
    shift
    case "${1:-}" in
      add)
        shift
        python3 "$KIPI_HOME/kipi-cluster-add.py" "$@"
        ;;
      sync)
        echo "Syncing KTLYST cluster bridge..."
        python3 "$HOME/.ktlyst/bridge/bridge-sync.py" 2>&1
        python3 "$HOME/.ktlyst/bridge/write-legal-flags.py" 2>&1
        python3 "$HOME/.ktlyst/bridge/write-website-state.py" 2>&1
        echo "Done. All bridge files updated."
        ;;
      *)
        echo "Usage:"
        echo "  kipi cluster add <path> <name> <role>"
        echo "  kipi cluster sync"
        ;;
    esac
    ;;
  list)
    python3 -c "
import json
d = json.load(open('$KIPI_HOME/instance-registry.json'))
print('Registered projects:')
for i in d['instances']:
    t = i.get('type', 'subtree')
    print(f\"  {i['name']:20s} {t:15s} {i['path']}\")
if d.get('excluded'):
    print()
    print('Excluded (different architecture):')
    for e in d['excluded']:
        print(f\"  {e['name']:20s} {e.get('reason', '')}\")
"
    ;;
  home)
    echo "$KIPI_HOME"
    ;;
  help|--help|-h|*)
    usage
    ;;
esac
